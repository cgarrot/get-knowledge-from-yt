# Copier vers .env.local (ne pas commiter .env.local — voir apps/web/.gitignore)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# Docker Compose : défini dans docker-compose.yml pour le SSR (hostname du service api)
# INTERNAL_API_URL=http://api:8000

# Dev : npm run dev → http://localhost:3030 (voir package.json)

# --- API FastAPI (shell ou .env à la racine / services/api, pas ce fichier) ---
# GKFY_WRITE_OUTPUT_FILES=1          # optionnel : écrire aussi data/output/*.md
# GKFY_REPO_EXPORT_DIR=knowledge-export  # optionnel : miroir Git sous <repo>/knowledge-export/
