# Exemple de variables pour uvicorn (exporter dans le shell ou utiliser un outil qui charge .env).
# Ne pas commiter de fichier .env réel avec des secrets — voir .gitignore à la racine.

# Provider gemini (clé API — secret utilisateur)
# GEMINI_API_KEY=

# OAuth Antigravity : URL exacte de l’API et du front
# GKFY_PUBLIC_API_URL=http://127.0.0.1:8000
# GKFY_FRONTEND_URL=http://localhost:3030
#
# redirect_uri Google (identique à l’échange de token). Défaut : http://localhost:51121/oauth-callback (opencode-antigravity-auth)
# Callback FastAPI à la place (après l’avoir ajouté dans Google Cloud) :
# GKFY_ANTIGRAVITY_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/antigravity/callback
# GKFY_ANTIGRAVITY_OAUTH_LOOPBACK_BIND=127.0.0.1

# Répertoire données (SQLite, prompts utilisateur, token Antigravity). Défaut : <repo>/data
# GKFY_DATA_DIR=/chemin/vers/data

# Exporter aussi les analyses en fichiers .md sous $GKFY_DATA_DIR/output (défaut : désactivé, tout reste en DB)
# GKFY_WRITE_OUTPUT_FILES=1
